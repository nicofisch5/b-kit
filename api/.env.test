APP_ENV=test
APP_SECRET=test_secret_bkit_not_for_production

# Test database — a separate DB on the same MariaDB server
DATABASE_URL="mysql://bkit:bkit_secret@database:3306/bkit_test?serverVersion=10.11.2-MariaDB&charset=utf8mb4"

# Reuse the same JWT keys as dev
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=bkit_jwt_passphrase
