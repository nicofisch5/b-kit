{
    "name": "bkit/api",
    "description": "B-Strack Basketball Stats API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": "^7.1",
        "symfony/runtime": "^7.1",
        "symfony/yaml": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/uid": "^7.1",
        "symfony/validator": "^7.1",
        "symfony/serializer": "^7.1",
        "symfony/property-access": "^7.1",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/dbal": "^4.0",
        "nelmio/cors-bundle": "^2.4"
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.60"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true
        },
        "sort-packages": true
    },
    "scripts": {
        "auto-scripts": {},
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "extra": {
        "symfony": {
            "allow-contrib": true
        }
    }
}
